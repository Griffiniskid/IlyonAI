# Copy your current production runtime secrets into this file.
# Do not commit the real deploy/prod/app.env file.

OPENROUTER_API_KEY=replace-me
HELIUS_API_KEY=replace-me
JUPITER_API_KEY=replace-me

POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://sentinel:replace-with-a-strong-password@postgres:5432/ilyon_ai
REDIS_URL=redis://redis:6379/0

SESSION_SECRET=replace-with-a-random-secret
LOG_LEVEL=INFO

WEB_API_PORT=8080
ACTIONS_API_PORT=8080
ACTIONS_BASE_URL=https://ilyonai.com
WEBAPP_URL=https://ilyonai.com
CORS_ORIGINS=https://ilyonai.com,https://www.ilyonai.com
