# Docker Compose settings for the private staging stack.
COMPOSE_PROJECT_NAME=ilyonai-staging
APP_ENV_FILE=deploy/staging/app.env
LOGS_DIR=./logs/staging

API_CONTAINER_PORT=8080
API_HOST_PORT=18080
WEB_HOST_PORT=13000

POSTGRES_DB=ilyon_ai_staging
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=replace-with-a-different-strong-password

NEXT_PUBLIC_API_URL=https://staging.ilyonai.com
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
