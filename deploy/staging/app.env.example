# Copy your runtime secrets into this file.
# Keep staging isolated from production where it matters.
# Use a different SESSION_SECRET, database password, and any staging-only tokens.

OPENROUTER_API_KEY=replace-me
HELIUS_API_KEY=replace-me
JUPITER_API_KEY=replace-me

POSTGRES_PASSWORD=replace-with-a-different-strong-password
DATABASE_URL=postgresql://sentinel:replace-with-a-different-strong-password@postgres:5432/ilyon_ai_staging
REDIS_URL=redis://redis:6379/0

SESSION_SECRET=replace-with-a-different-random-secret
LOG_LEVEL=INFO

WEB_API_PORT=8080
ACTIONS_API_PORT=8080
ACTIONS_BASE_URL=https://staging.ilyonai.com
WEBAPP_URL=https://staging.ilyonai.com
CORS_ORIGINS=https://staging.ilyonai.com
