# ──────────────────────────────────────────────────────────────────────────────
# Agent Platform — Environment Variables
# Copy this file to .env and fill in your keys.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Keys ───────────────────────────────────────────────────────────────────
# JSON object — include only the keys you have. At least one LLM key is required.
# Priority order: openrouter → groq → openai
#
# LLM providers:
#   openrouter        Free models at openrouter.ai/keys              (sk-or-v1-...)
#   groq              Free fast inference at console.groq.com         (gsk_...)
#   openai            Paid, at platform.openai.com                   (sk-...)
#
# DeFi integrations (optional):
#   jupiter_fee_account   Your Solana ATA — receives Jupiter platform fees (0.5%)
#
API_KEYS={"openrouter": "sk-or-v1-...", "groq": "gsk_...", "openai": "sk-...", "jupiter_fee_account": "YourSolanaATA"}

# Enso Finance same-chain transaction API key
ENSO_API_KEY=your-enso-api-key

# EVM wallet that receives the 0.5% platform fee for Enso + deBridge flows
# If unset, the backend safely skips fee collection.
PLATFORM_FEE_WALLET_EVM=0x000000000000000000000000000000000000dEaD

# Optional deBridge referral code used for analytics / points attribution
DEBRIDGE_REFERRAL_CODE=

# ── Auth ────────────────────────────────────────────────────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-random-64-char-hex

# ── RPC URLs (optional — built-in fallbacks used if empty) ─────────────────────
# Chain IDs: 204 = opBNB mainnet, 5611 = opBNB testnet, 56 = BNB Smart Chain
RPC_URLS={}
# Example:
# RPC_URLS={"204": "https://opbnb-mainnet-rpc.bnbchain.org", "56": "https://bsc-dataseed.binance.org"}
