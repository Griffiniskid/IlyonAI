# =============================================================================
# AI Sentinel - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================


# =============================================================================
# AI PROVIDERS (At least one required)
# =============================================================================

# OpenRouter - Recommended (access to multiple models)
# Get API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# OpenAI Direct - Alternative
# Get API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model configuration (defaults work well)
AI_MODEL=openai/gpt-4o-mini
OPENAI_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini


# =============================================================================
# SOLANA BLOCKCHAIN
# =============================================================================
# AI Sentinel is Solana-exclusive. These settings configure Solana access.

# Public RPC (rate limited) - Use Helius for production
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API - Recommended for production (faster, more reliable)
# Get free API key: https://dev.helius.xyz/
HELIUS_API_KEY=


# =============================================================================
# HONEYPOT DETECTION (Optional - defaults work well)
# =============================================================================

# SOL amount to simulate selling (for tax detection)
HONEYPOT_SIMULATION_SOL=0.1

# Tax thresholds (percentage)
HONEYPOT_HIGH_TAX_THRESHOLD=20.0
HONEYPOT_EXTREME_TAX_THRESHOLD=50.0

# Jupiter API timeout (seconds)
JUPITER_API_TIMEOUT=15

# Jupiter API Key (REQUIRED as of Jan 31, 2026)
# Get your free API key at: https://portal.jup.ag
# Free tier: 60 requests/minute
JUPITER_API_KEY=


# =============================================================================
# DATABASE (Optional - enables persistent storage)
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database

DATABASE_URL=

# For Docker deployment
POSTGRES_PASSWORD=


# =============================================================================
# CACHING (Optional)
# =============================================================================

# Redis URL for caching (falls back to in-memory if not set)
REDIS_URL=

# Cache TTL in seconds (default: 2 minutes)
CACHE_TTL=120

# Analysis timeout in seconds
ANALYSIS_TIMEOUT=30


# =============================================================================
# MONETIZATION (Optional)
# =============================================================================
# Trojan Bot affiliate code for buy buttons
# Get referral link: https://t.me/solana_trojanbot

TROJAN_REF=


# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional - logs to console if not set)
LOG_FILE=

# Log rotation settings
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Privacy settings
LOG_AI_FULL_RESPONSES=true
LOG_REDACT_SENSITIVE=true


# =============================================================================
# SOLANA ACTIONS / BLINKS (Optional)
# =============================================================================
# Enable shareable analysis links that unfurl on Twitter

# Base URL for your API (must be HTTPS in production)
ACTIONS_BASE_URL=https://api.ilyonai.io

# Port for Blinks API server
ACTIONS_API_PORT=8080

# Enable/disable Blinks feature
BLINKS_ENABLED=true

# Rate limiting
BLINKS_RATE_LIMIT_PER_MINUTE=30
BLINKS_RATE_LIMIT_PER_HOUR=200

# Blink expiration (hours, 0 = never expire)
BLINK_TTL_HOURS=168
